# LLM Configuration

# Model Selection (Ollama Cloud)
# Compatible models: ministral-3:3b, gemini-3-flash-preview
MODEL_TASKS=ministral-3:3b           # Primary model for tasks extraction
MODEL_SUMMARY=gemini-3-flash-preview # Faster model for summaries
MODEL_ENTITIES=ministral-3:3b        # Model for entities

LLM_API_KEY=your-ollama-cloud-api-key
OLLAMA_BASE_URL=ollama-cloud

# For Ollama local deployment:
# LLM_API_KEY=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# MODEL_TASKS=ministral-3:3b
# MODEL_SUMMARY=ministral-3:3b
# MODEL_ENTITIES=ministral-3:3b

# For OpenAI:
# LLM_API_KEY=sk-your-openai-key
# OLLAMA_BASE_URL=
# MODEL_TASKS=gpt-4o-mini
# MODEL_SUMMARY=gpt-4o-mini
# MODEL_ENTITIES=gpt-4o-mini

# For Anthropic:
# LLM_API_KEY=sk-ant-your-anthropic-key
# USE_ANTHROPIC=true
# MODEL_TASKS=claude-3-haiku-20240307
# MODEL_SUMMARY=claude-3-haiku-20240307
# MODEL_ENTITIES=claude-3-haiku-20240307

# API Authentication (optional - set to enable)
# REQUIRED_API_KEY=your-secret-api-key
# API_KEY_HEADER=X-API-Key

# Batch Processing (optional)
# BATCH_ENABLED=true
# BATCH_SIZE=3

