{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["status", "data", "meta"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "data": {
      "type": "object",
      "required": ["tasks", "summary"],
      "properties": {
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["task", "priority", "deadline", "source"],
            "properties": {
              "task": { "type": "string" },
              "priority": { "type": "string", "enum": ["low", "medium", "high"] },
              "deadline": { "type": ["string", "null"] },
              "source": { "type": "string" }
            }
          }
        },
        "summary": { "type": "string" }
      }
    },
    "meta": {
      "type": "object",
      "required": ["chunks_used", "tokens_used", "docs_processed"],
      "properties": {
        "chunks_used": { "type": "integer" },
        "tokens_used": { "type": "integer" },
        "docs_processed": { "type": "integer" }
      }
    }
  }
}
