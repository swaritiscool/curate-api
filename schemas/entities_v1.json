{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["status", "data", "meta"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "data": {
      "type": "object",
      "required": ["entities"],
      "properties": {
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "source"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string", "enum": ["person", "organization", "date", "location", "other"] },
              "source": { "type": "string" }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "required": ["chunks_used", "tokens_used", "docs_processed"],
      "properties": {
        "chunks_used": { "type": "integer" },
        "tokens_used": { "type": "integer" },
        "docs_processed": { "type": "integer" }
      }
    }
  }
}
